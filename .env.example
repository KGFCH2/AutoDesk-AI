# Environment Variables for AutoDesk AI
# Copy this file to .env and fill in your actual API keys

# Notion API Configuration
# Get your API key from: https://www.notion.com/my-integrations
VITE_NOTION_API_KEY=your_notion_api_key_here

# Your Notion database ID (from the URL of your database)
VITE_NOTION_DATABASE_ID=your_database_id_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here