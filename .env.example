# Notion Configuration
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Groq Configuration
GROQ_API_KEY=your_groq_api_key_here

# Note: These keys must NOT have the VITE_ prefix to remain secure.
# They will be used by the backend proxy in 'api/*.ts' and are hidden from the browser.
