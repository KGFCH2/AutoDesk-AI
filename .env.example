# Environment Variables for AutoDesk AI
# Copy this file to .env and fill in your actual API keys

# Notion API Configuration
# Get your API key from: https://www.notion.com/my-# Notion Integration
VITE_NOTION_API_KEY=your_notion_api_key_here
VITE_NOTION_DATABASE_ID=your_notion_database_id_here

# Groq API Key (AI Processing)
VITE_GROQ_API_KEY=your_groq_api_key_here
